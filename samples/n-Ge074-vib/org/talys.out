 deuteronomp         4     deuteronomp  deuteron OMP (1=normal, 2=Daehnick, 3=Bojowald, 4=Han-Shi-Shen, 5=An-Cai)
 ecisstep         0.00E+00 ecisstep     integration step size for ECIS OMP calculation
 #
 # Compound nucleus
 #
 widthfluc           y     flagwidth    flag for width fluctuation calculation
