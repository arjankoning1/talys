 rpevap              n     flagrpevap   flag for evaporation of residual products at high incident energies
 legacy              n     flaglegacy   flag to run legacy models
 maxZrp             12     maxZrp       maximal number of protons from the initial CN before residual evaporation
 maxNrp             32     maxNrp       maximal number of neutrons from the initial CN before residual evaporation
 user      Arjan Koning    user         user for this calculation
 source    TALYS-2.2       source       source for this calculation
 format    YANDF-0.4       oformat      format for output
 #
 # Optical model
 #
 localomp            y     flaglocalomp flag for local (y) or global (n) optical model
 globaldisp          n   flagglobaldisp flag for global dispersive optical model
 globalfermi         y  flagglobalfermi flag for global Fermi energy
 dispersion          n     flagdisp     flag for dispersive optical model
